            constexpr int32_t kGroupVecWidth = kThreadGroupSize * VEC_WIDTH;

            if constexpr (kUseVecBlocking) {
                const int32_t num_vecs = (D + kGroupVecWidth - 1) / kGroupVecWidth;

                compute_grad_sum_unweighted_vbe<
