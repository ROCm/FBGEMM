        } else {
            s_momentum1 = &momentum1_uvm[s_momentum1_offset];
        }
        // cache_t s_momentum1_val = is_valid? s_momentum1[s_idx]: 0;

        for (auto i = 0; i < num_valid_id; ++i) {
            auto run_id = out_run_id + i;
            auto t_0 = SUBWARP_SHFL_SYNC(s_t_0, i);
            auto segment_start = SUBWARP_SHFL_SYNC(s_segment_start, i);
            auto segment_end = SUBWARP_SHFL_SYNC(s_segment_end, i);
            
            auto D = SUBWARP_SHFL_SYNC(s_D, i);
            int32_t table_unique_indice_offset = SUBWARP_SHFL_SYNC(s_table_unique_indice_offset, i);
            const int32_t SL = segment_end - segment_start;

            auto idx = SUBWARP_SHFL_SYNC(s_idx, i);
            auto weights_offset = SUBWARP_SHFL_SYNC(s_weights_offset, i);
            auto weights_placement = static_cast<PlacementType>(SUBWARP_SHFL_SYNC(s_weights_placement, i));

            auto momentum1 = reinterpret_cast<at::acc_type<cache_t, true>*>(SUBWARP_SHFL_SYNC(reinterpret_cast<uint64_t>(s_momentum1), i));

            auto momentum1_val = momentum1[idx];
        
            if (SL >= max_segment_length_per_warp) {
                continue;
            }

            // now, each segment corresponds to exactly one table `t` and row in
            // that table (`idx`). Thus, we can hoist out some of the book-keeping.

            // D can be hoisted here because D is the same if features share the
            // same table, but D_start is different

            const int32_t sl_start = 0;
            const int32_t sl_end = SL;
            Vec4TAcc<cache_t> grad_sum[kFixedMaxVecsPerThread];
            constexpr int32_t kGroupVecWidth = kThreadGroupSize * VEC_WIDTH;

            if constexpr (kUseVecBlocking) {
                const int32_t num_vecs = (D + kGroupVecWidth - 1) / kGroupVecWidth;

                compute_grad_sum_unweighted_vbe<
                grad_t,
                cache_t,
                kFixedMaxVecsPerThread,
                kThreadGroupSize,
                VEC_WIDTH,
                kUseVecBlocking>(
                    grad_sum,
                    smem_grad_sum,
                    grad_output,
                    D_offsets,
                    D,
                    T,
                    sorted_infos,
                    B_offsets,
                    row_output_offsets,
                    info_B_num_bits,
                    info_B_mask,
                    segment_start,
                    sl_start,
                    sl_end,
                    shfl_sync_mask,
                    num_vecs
                );
            } else {
                // Reset grad_sum vectors
                #pragma unroll kFixedMaxVecsPerThread
                for (int32_t vec = 0; vec < kFixedMaxVecsPerThread; vec++) {
                    grad_sum[vec].acc.x = 0;
                    grad_sum[vec].acc.y = 0;
                    grad_sum[vec].acc.z = 0;
                    grad_sum[vec].acc.w = 0;
                }

                for (int32_t sl = sl_start; sl < sl_end; sl += kThreadGroupSize) {
                    auto sl_j = sl + threadIdx.x;
                    const auto b_t = sl_j < sl_end
                        ? reinterpret_cast<const uint32_t*>(
                            &sorted_infos[0])[segment_start + sl_j]
                        : 0;
                    const auto b = b_t & info_B_mask;
                    const auto t = b_t >> info_B_num_bits;
                    const auto grad_offset = row_output_offsets[B_offsets[t] + b]; // if vbe // if not nobag
                    int32_t j = 0;

                    for (; j + 7 < kThreadGroupSize && sl + j + 7 < sl_end; j+=8) {
                        const auto grad_offset_j_0 = SUBWARP_SHFL_SYNC(grad_offset, j);
                        const auto grad_offset_j_1 = SUBWARP_SHFL_SYNC(grad_offset, j + 1);
                        const auto grad_offset_j_2 = SUBWARP_SHFL_SYNC(grad_offset, j + 2);
                        const auto grad_offset_j_3 = SUBWARP_SHFL_SYNC(grad_offset, j + 3);
                        const auto grad_offset_j_4 = SUBWARP_SHFL_SYNC(grad_offset, j + 4);
                        const auto grad_offset_j_5 = SUBWARP_SHFL_SYNC(grad_offset, j + 5);
                        const auto grad_offset_j_6 = SUBWARP_SHFL_SYNC(grad_offset, j + 6);
                        const auto grad_offset_j_7 = SUBWARP_SHFL_SYNC(grad_offset, j + 7);

                        #pragma unroll kFixedMaxVecsPerThread
                        for (int32_t vec = 0; vec < kFixedMaxVecsPerThread && ((vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH) < D; ++vec) {
                            const int32_t d = ((vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH);
                            Vec4TAcc<grad_t> grad_out_vec_0(&grad_output[0][grad_offset_j_0 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_1(&grad_output[0][grad_offset_j_1 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_2(&grad_output[0][grad_offset_j_2 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_3(&grad_output[0][grad_offset_j_3 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_4(&grad_output[0][grad_offset_j_4 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_5(&grad_output[0][grad_offset_j_5 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_6(&grad_output[0][grad_offset_j_6 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_7(&grad_output[0][grad_offset_j_7 + d]);  // if nobag

                            grad_sum[vec].add_(grad_out_vec_0);
                            grad_sum[vec].add_(grad_out_vec_1);
                            grad_sum[vec].add_(grad_out_vec_2);
                            grad_sum[vec].add_(grad_out_vec_3);
                            grad_sum[vec].add_(grad_out_vec_4);
                            grad_sum[vec].add_(grad_out_vec_5);
                            grad_sum[vec].add_(grad_out_vec_6);
                            grad_sum[vec].add_(grad_out_vec_7);
                        }
                    }

                    for (; j + 3 < kThreadGroupSize && sl + j + 3 < sl_end; j+=4) {
                        const auto grad_offset_j_0 = SUBWARP_SHFL_SYNC(grad_offset, j);
                        const auto grad_offset_j_1 = SUBWARP_SHFL_SYNC(grad_offset, j + 1);
                        const auto grad_offset_j_2 = SUBWARP_SHFL_SYNC(grad_offset, j + 2);
                        const auto grad_offset_j_3 = SUBWARP_SHFL_SYNC(grad_offset, j + 3);

                        #pragma unroll kFixedMaxVecsPerThread
                        for (int32_t vec = 0; vec < kFixedMaxVecsPerThread && ((vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH) < D; ++vec) {
                            const int32_t d = ((vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH);
                            Vec4TAcc<grad_t> grad_out_vec_0(&grad_output[0][grad_offset_j_0 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_1(&grad_output[0][grad_offset_j_1 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_2(&grad_output[0][grad_offset_j_2 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_3(&grad_output[0][grad_offset_j_3 + d]);  // if nobag

                            grad_sum[vec].add_(grad_out_vec_0);
                            grad_sum[vec].add_(grad_out_vec_1);
                            grad_sum[vec].add_(grad_out_vec_2);
                            grad_sum[vec].add_(grad_out_vec_3);
                        }
                    }

                    for (; j + 1 < kThreadGroupSize && sl + j + 1 < sl_end; j+=2) {
                        const auto grad_offset_j_0 = SUBWARP_SHFL_SYNC(grad_offset, j);
                        const auto grad_offset_j_1 = SUBWARP_SHFL_SYNC(grad_offset, j + 1);

                        #pragma unroll kFixedMaxVecsPerThread
                        for (int32_t vec = 0; vec < kFixedMaxVecsPerThread && ((vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH) < D; ++vec) {
                            const int32_t d = ((vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH);
                            Vec4TAcc<grad_t> grad_out_vec_0(&grad_output[0][grad_offset_j_0 + d]);  // if nobag
                            Vec4TAcc<grad_t> grad_out_vec_1(&grad_output[0][grad_offset_j_1 + d]);  // if nobag

                            grad_sum[vec].add_(grad_out_vec_0);
                            grad_sum[vec].add_(grad_out_vec_1);
                        }
                    }

                    for (; j < kThreadGroupSize && sl + j < sl_end; ++j) {
                        const auto grad_offset_j = SUBWARP_SHFL_SYNC(grad_offset, j);

                        #pragma unroll kFixedMaxVecsPerThread
                        for (int32_t vec = 0; vec < kFixedMaxVecsPerThread && ((vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH) < D; ++vec) {
                            const int32_t d = ((vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH);
                            Vec4TAcc<grad_t> grad_out_vec(
                                &grad_output[0][grad_offset_j + d] // if nobag
                            );
                            grad_sum[vec].add_(grad_out_vec);
                        }
                    }
                }

                if (smem_grad_sum) {
                    // Store grad_sum in smem_grad_sum
                    #pragma unroll kFixedMaxVecsPerThread
                    for (int32_t vec = 0;
                        (vec < kFixedMaxVecsPerThread) && (vec * kThreadGroupSize + threadIdx.x) * VEC_WIDTH < D;
                        ++vec) {
                        const int32_t d_vec = (vec * kThreadGroupSize + threadIdx.x);
                        smem_grad_sum[d_vec] = grad_sum[vec];
                    }
                }
            }

            // Copy value to max_vecs to make max_vecs_per_thread known at compile time
            // when kUseVecBlocking == false
            const int32_t max_vecs =
                kUseVecBlocking ? max_vecs_per_thread : kFixedMaxVecsPerThread;
            split_rowwise_adagrad_table_update_kernel_device_maxD_128<
            emb_t,
            cache_t,
            kFixedMaxVecsPerThread,
            kThreadGroupSize,
            VEC_WIDTH,
            kUseVecBlocking>(
                dev_weights,
                uvm_weights,
                lxu_cache_weights,
                weights_placement,
                weights_offset,
                sorted_lxu_cache_locations,
                grad_sum,
                smem_grad_sum,
                smem_grad_sum, // shared_weight_update_row (reuse smem_grad_sum)
                stochastic_rounding,
                stochastic_rounding_philox_args,
                run_id,
                use_uniq_cache_locations
                    ? (run_id - table_unique_indice_offset)
                    : segment_start,
                D,
                t_0,
                idx,
                
                1, // global_weight_decay
                shfl_sync_mask,
                max_vecs,
                momentum1, momentum1_val, learning_rate, eps, weight_decay, weight_decay_mode, max_norm
                // momentum1_dev, momentum1_uvm, momentum1_placement, momentum1_offset, learning_rate, eps, weight_decay, weight_decay_mode, max_norm
            ); // if not dense and optimizer != "none"
        }
    }
}

