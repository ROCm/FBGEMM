        int32_t s_segment_end = is_valid ? sorted_linear_indices_cumulative_run_lengths[(out_run_id + threadIdx.x + 1)] : -1;
        int64_t s_idx = is_valid ? sorted_linear_indices_run[(out_run_id + threadIdx.x)] : -1;

